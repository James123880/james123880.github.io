<button onclick="toggleMusic()" id="musicBtn">
  🔊 播放音乐
</button>

<audio id="music" src="music.mp3" loop></audio>

<script>
function toggleMusic() {
  const music = document.getElementById("music");
  const btn = document.getElementById("musicBtn");

  if (music.paused) {
    music.play();
    btn.innerText = "🔇 关闭音乐";
  } else {
    music.pause();
    btn.innerText = "🔊 播放音乐";
  }
}
</script>
